{% assign gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .collection-description-{{ gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .collection-description__container-{{ gen_id }} {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 15px;
    box-sizing: border-box;
  }

  .collection-description__content-{{ gen_id }} {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  /* Shopify common rich-text wrapper */
  .collection-description__rte-{{ gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_align }};
  }

  /* H2 heading inside content: 16px, bold */
  .collection-description__rte-{{ gen_id }} h2 {
    font-size: 16px;
    margin: 0 0 10px;
    line-height: 1.3;
    font-weight: 600;
  }

  /* H3 heading inside content: 14px, bold */
  .collection-description__rte-{{ gen_id }} h3 {
    font-size: 14px;
    margin: 0 0 10px;
    line-height: 1.3;
    font-weight: 600;
  }

  .collection-description__rte-{{ gen_id }} a {
    color: #E95144;
    text-decoration: underline;
  }

  .collection-description__rte-{{ gen_id }} a:hover {
    color: #d43b2f;
    text-decoration: none;
  }

  .collection-description__text-{{ gen_id }} {
    margin: 0 0 10px;
  }

  .collection-description__text-{{ gen_id }}.is-collapsed {
    display: -webkit-box;
    -webkit-line-clamp: {{ block.settings.preview_lines }};
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .collection-description__toggle-{{ gen_id }} {
    display: inline-flex;
    align-self: flex-end;
    background: none;
    border: none;
    color: {{ block.settings.button_color }};
    font-size: {{ block.settings.button_size }}px;
    cursor: pointer;
    padding: 8px 0;
    transition: color 0.3s ease;
    margin-left: auto;
  }

  .collection-description__toggle-{{ gen_id }}:hover {
    color: {{ block.settings.button_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .collection-description__container-{{ gen_id }} {
      padding: 0 15px;
    }
  }
{% endstyle %}

{% if collection.description != blank %}
  <collection-description-{{ gen_id }}
    class="collection-description-{{ gen_id }}"
    {{ block.shopify_attributes }}
  >
    <section class="collection-description__container-{{ gen_id }}">
      <div class="collection-description__content-{{ gen_id }}">
        <div class="rte collection-description__rte-{{ gen_id }}">
          <div class="collection-description__text-{{ gen_id }} is-collapsed">
            {{ collection.description }}
          </div>
        </div>

        <button
          class="collection-description__toggle-{{ gen_id }}"
          type="button"
          aria-expanded="false"
          data-read-more
        >
          {{ block.settings.read_more_text }}
        </button>
      </div>
    </section>
  </collection-description-{{ gen_id }}>

  <script>
    (function() {
      class CollectionDescription{{ gen_id }} extends HTMLElement {
        constructor() {
          super();
          this.button = this.querySelector('[data-read-more]');
          this.textContainer = this.querySelector('.collection-description__text-{{ gen_id }}');
          this.isExpanded = false;
          this.readMoreText = '{{ block.settings.read_more_text }}';
          this.showLessText = '{{ block.settings.show_less_text }}';
        }

        connectedCallback() {
          if (!this.button || !this.textContainer) return;

          this.checkIfTruncated();
          this.button.addEventListener('click', this.toggleDescription.bind(this));
        }

        checkIfTruncated() {
          if (this.textContainer.scrollHeight <= this.textContainer.clientHeight) {
            this.button.style.display = 'none';
          }
        }

        toggleDescription() {
          this.isExpanded = !this.isExpanded;

          if (this.isExpanded) {
            this.textContainer.classList.remove('is-collapsed');
            this.button.textContent = this.showLessText;
            this.button.setAttribute('aria-expanded', 'true');
          } else {
            this.textContainer.classList.add('is-collapsed');
            this.button.textContent = this.readMoreText;
            this.button.setAttribute('aria-expanded', 'false');
          }
        }
      }

      customElements.define('collection-description-{{ gen_id }}', CollectionDescription{{ gen_id }});
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Collection description",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "preview_lines",
      "min": 2,
      "max": 10,
      "step": 1,
      "label": "Preview lines",
      "default": 3
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "read_more_text",
      "label": "Read more text",
      "default": "Read More"
    },
    {
      "type": "text",
      "id": "show_less_text",
      "label": "Show less text",
      "default": "Show Less"
    },
    {
      "type": "range",
      "id": "button_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Button size",
      "default": 14
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover color",
      "default": "#666666"
    }
  ],
  "presets": [
    {
      "name": "Collection description"
    }
  ]
}
{% endschema %}