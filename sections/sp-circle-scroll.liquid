  </div>

  <div class="sp-grid-container">
    <div class="sp-grid">

      {% assign index = 0 %}

      {% for block in section.blocks %}

        
        {% if block.type == 'collection' %}

          {% if block.settings.collection %}

            {% for product in block.settings.collection.products %}

              <style>
                #sp-cmw-{{ short_id }}-{{ index }} .sp-circle-wrap {
                  text-decoration: none;

                  {% assign remainder_2 = index | modulo: 2 %}
                  {% assign remainder_3 = index | modulo: 3 %}

                  {% if remainder_2 == 0 %}
                    background-image: {{ block.settings.background_color_2 }};
                  {% elsif remainder_3 == 0 %}
                    background-image: {{ block.settings.background_color_3 }};
                  {% else %}
                    background-image: {{ block.settings.background_color_1 }};
                  {% endif %}
                }
              </style>

              <div class="sp-col" data-index="{{ index }}" sp-column>
                <a id="sp-cmw-{{ short_id }}-{{ index }}" href="{{ product.url }}">
                  <span class="sp-circle-wrap">
                    {% if product.featured_media %}
                      <img src="{{ product.featured_media | image_url: width: 500 }}">
                    {% else %}
                      <img src="data:image/svg+xml,%3C%3Fxml version='1.0' encoding='UTF-8'%3F%3E%3Csvg version='1.1' viewBox='0 0 500 500' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Crect x='2' y='2' width='496' height='496' fill='%23C8C8C8' stroke='%23D8D8D8' stroke-width='4'/%3E%3C/g%3E%3C/svg%3E">
                    {% endif %}
                  </span>
                  <span class="sp-circle-text">{{ product.title }}</span>
                </a>
              </div>

              {% assign index = index | plus:1 %}

            {% endfor %}

          {% endif %}

        {% endif %}

        {% if block.type == 'video' or block.type == 'image' %}

        <div class="sp-col" data-index="{{ index }}" sp-column>

          <style>
            #sp-cmw-{{ short_id }}-{{ index }} .sp-circle-wrap {
              text-decoration: none;
              background-image: {{ block.settings.background_color }};
            }
          </style>

          {% if block.type == 'video' %}
          
            {% if block.settings.link %}
              <a id="sp-cmw-{{ short_id }}-{{ index }}" href="{{ block.settings.link }}">
                <span class="sp-circle-wrap">
                {% if block.settings.video %}
                {{
                  block.settings.video
