                  {% endif %}
                </span>
                <span class="sp-circle-text">{{ block.settings.text }}</span>
              </a>
            {% endif %}
          {% endif %}
        </div>

        {% assign index = index | plus:1 %}
      {% endif %}

      {% endfor %}

    </div>
