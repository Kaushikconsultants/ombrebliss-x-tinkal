    width: 25px;
    fill: {{ section.settings.arrow_icon_color }};
  }

  #sp-{{ section.id }} .sp-previous {
    position: absolute;
    top: calc(50% - 25px);
    left: -20px;
    transform: rotate(180deg);
  }

  #sp-{{ section.id }} .sp-next {
    position: absolute;
    top: calc(50% - 25px);
    right: -20px;
  }

  {%- endcapture -%} 

  {%- liquid
    assign chunks = sp_content | strip_newlines | split: ' ' | join: ' ' | split: '*/'
    for chunk in chunks
      assign mini = chunk | split: '/*' | first | strip | replace: ': ', ':' | replace: '; ', ';' | replace: '} ', '}' | replace: '{ ', '{' | replace: ' {', '{' | replace: ';}', '}'
      echo mini
    endfor
  %}
