    text-align: {{ section.settings.text_alignment }};
  }

  @media only screen and (max-width: 800px) {
    #sp-{{ section.id }} .sp-headline * {
      text-align: {{ section.settings.mobile_text_alignment }};
    }
  }

  /* grid */
  #sp-{{ section.id }}  .sp-container .sp-grid-container {
    position: relative;
  }

  #sp-{{ section.id }}  .sp-container .sp-grid {
    position: relative;
  }
  
  #sp-{{ section.id }}  .sp-container .sp-grid {
    display: grid;
    align-items: center;
    gap: {{ section.settings.grid_gap}}px;
    position: relative;
    z-index: 0;
  }

  #sp-{{ section.id }} .sp-container .sp-grid {
    display: grid;
    grid-auto-columns: 1fr;
    grid-auto-flow: column;

  }

  #sp-{{ section.id }} .sp-container .sp-grid {
    display: grid;
    grid-auto-columns: {{ section.settings.circle_width }}px;
    grid-auto-flow: column;
    white-space: nowrap;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    gap: {{ section.settings.grid_gap }}px;
  }

  /* col */
  #sp-{{ section.id }} .sp-col {
    height: 100%;
    scroll-snap-align: center;
    white-space: normal;
    box-sizing: border-box;
    position: relative;
    margin: 0;
    padding: 0;
    overflow: hidden;
  }

  #sp-{{ section.id }} .sp-col .sp-circle-wrap {
    display: inline-block;
    padding: 0;
    {% if section.settings.circle_ring %}padding: 5px;{% endif %}
    {% if section.settings.circle_shadow %}
      box-shadow: 0 0 5px 0 rgba(0,0,0,0.20);
      margin: 5px;
    {% endif %}
    border-radius: {{ section.settings.circle_radius }}%;
  }

  @media only screen and (max-width: 800px) {
    #sp-{{ section.id }} .sp-col {
      width: calc(100% - 10px);
    }
  }

  #sp-{{ section.id }} .sp-col a {
    text-decoration: none;
  }

  #sp-{{ section.id }} .sp-col .sp-circle-text {
    display: block;
    text-align: center;
    text-decoration: none;
    font-size: {{ section.settings.text_size }}px;
    {% if section.settings.override_fonts %}
    font-family: {{ section.settings.text_font.family }}, {{ section.settings.text_font.fallback_families }};
    font-weight: {{ section.settings.text_font.weight }};
    {% endif %}
    color: {{ section.settings.text_color }};
    line-height: 1.25;
  }
  
  #sp-{{ section.id }} .sp-col img,
  #sp-{{ section.id }} .sp-col video {
    display: block;
    width: 100%;
    border-top-left-radius: 5px;
    border-top-right-radius: 5px;
    object-fit: cover;
    aspect-ratio: 1 / 1;
    padding: 0;
    margin: 0;
    {% if section.settings.circle_border %}border: 3px solid {{ section.settings.circle_border_color }};{% endif %}
    border-radius: {{ section.settings.circle_radius }}%;
  }

  /* arrows */
  #sp-{{ section.id }} .sp-previous,
  #sp-{{ section.id }} .sp-next {
    display: flex;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background-image: {{ section.settings.arrow_background_color }};
    justify-content: center;
    align-items: center;
    text-align: center;
    cursor: pointer;
    z-index: 1;
    margin: 0;
    padding: 0;
    opacity: 1;
    transition: all .5s ease;
  }
  #sp-{{ section.id }} .sp-previous[hidden],
  #sp-{{ section.id }} .sp-next[hidden] {
