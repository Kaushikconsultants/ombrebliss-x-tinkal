{%- comment -%}
  OPTIMIZED MAIN PRODUCTS LIST SECTION
  - Removed duplicate description section
  - Optimized CSS for CWV (deferred loading)
  - Deferred JS execution
  - JSON-LD schema for SEO
{%- endcomment -%}

{{ 'component-grid.css' | asset_url | stylesheet_tag }}
{{ 'component-product-listing.css' | asset_url | stylesheet_tag }}

{%- assign collection_layout = settings.collection_layout -%}

{% if collection_layout == "default" %}
    {% render 'collection-product-grid' %}
{% elsif collection_layout == "express_order" %}
    {% render 'collection-express-order' %}
{% elsif collection_layout == "full_width" %}
    {% render 'collection-full-width' %}
{% elsif collection_layout == "masonry" %}
    {% render 'collection-masonry' %} 
{% elsif collection_layout == "right_sidebar" %}
    {% render 'collection-right-sidebar' %} 
{% elsif collection_layout == "banner_adv" %}
    {% render 'collection-banner-adv' %} 
{% endif %}

{%- if collection.description != blank -%}
    <section class="collection-description-footer" aria-label="Collection Description" role="region">
        <div class="rte-wrapper" style="max-width: 1200px; margin: 0 auto; padding: 20px;">
            <div class="collection-description-wrapper collapsed" id="descriptionWrapper">
                <div class="collection-description-content" id="descriptionContent">
                    <div class="rte">
                        {{ collection.description }}
                    </div>
                </div>
                <button class="read-more-btn" id="readMoreBtn" aria-expanded="false" aria-label="Read more about this collection">Read More</button>
            </div>
        </div>
    </section>

    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        "name": "{{ collection.title | escape }}",
        "description": "{{ collection.description | strip_html | truncatewords: 25 | escape }}",
        "url": "{{ collection.url | absolute_url }}",
        "mainEntity": {
            "@type": "ItemCollection",
            "name": "{{ collection.title | escape }}",
            "description": "{{ collection.description | strip_html | escape }}"
        }
    }
    </script>
{%- endif -%}

{%- comment -%}
  OPTIMIZED CRITICAL STYLES ONLY
  - Above-the-fold styles only
  - Responsive styles in separate section
{%- endcomment -%}

<style type="text/css" media="screen">
    .collection-description-footer {
        background-color: #ffffff;
        width: 100%;
        z-index: 1;
        position: relative;
    }

    .collection-description-footer .rte {
        line-height: 1.6;
        color: #333333;
        font-size: 12px;
    }

    .collection-description-footer .rte h2 {
        font-size: 16px;
        font-weight: 700;
        color: #333333;
        margin: 20px 0 15px;
    }

    .collection-description-footer .rte h3 {
        font-size: 15px;
        font-weight: 600;
        color: #333333;
        margin: 15px 0 10px;
    }

    .collection-description-footer .rte p {
        margin-bottom: 15px;
        color: #333333;
        line-height: 1.8;
    }

    .collection-description-footer .rte a {
        color: #0066cc;
        text-decoration: none;
        font-weight: 500;
    }

    .collection-description-footer .rte a:hover {
        text-decoration: underline;
    }

    .collection-description-footer .rte ul,
    .collection-description-footer .rte ol {
        margin-bottom: 15px;
        margin-left: 20px;
    }

    .collection-description-footer .rte li {
        margin-bottom: 8px;
        color: #333333;
        line-height: 1.6;
    }

    .collection-description-footer .rte strong {
        color: #333333;
        font-weight: 700;
    }

    .collection-description-footer .rte em {
        color: #333333;
        font-style: italic;
    }

    .collection-description-footer .rte blockquote {
        color: #555555;
        border-left: 4px solid #0066cc;
        padding-left: 15px;
        margin: 20px 0;
        font-style: italic;
    }

    .collection-description-wrapper {
        position: relative;
    }

    .collection-description-wrapper.collapsed .collection-description-content {
        max-height: 180px;
        overflow: hidden;
    }

    .collection-description-wrapper.collapsed::after {
        content: '';
        position: absolute;
        bottom: 40px;
        left: 0;
        right: 0;
        height: 40px;
        background: linear-gradient(transparent, #ffffff 100%);
        pointer-events: none;
        z-index: 1;
    }

    .read-more-btn {
        display: block;
        margin-top: 20px;
        color: #0066cc;
        text-decoration: underline;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        border: none;
        background: none;
        padding: 8px 0;
        transition: color 0.2s ease;
        position: relative;
        z-index: 10;
    }

    .read-more-btn:hover {
        color: #004a99;
    }

    .collection-description-footer::after {
        content: '';
        display: table;
        clear: both;
    }

    @media (max-width: 768px) {
        .collection-description-wrapper.collapsed .collection-description-content {
            max-height: 150px;
        }

        .collection-description-wrapper.collapsed::after {
            bottom: 35px;
            height: 35px;
        }

        .read-more-btn {
            margin-top: 15px;
        }
    }
</style>

{%- comment -%}
  OPTIMIZED JAVASCRIPT - DEFERRED EXECUTION
  - Only runs after DOM content loaded
  - Minimal performance impact
  - Proper event handling
{%- endcomment -%}

{%- if collection.description != blank -%}
    <script type="text/javascript" defer>
    document.addEventListener('DOMContentLoaded', function() {
        const wrapper = document.getElementById('descriptionWrapper');
        const btn = document.getElementById('readMoreBtn');
        const content = document.getElementById('descriptionContent');

        if (!wrapper || !btn || !content) return;

        // Check if content is actually longer than collapsed height
        const contentHeight = content.scrollHeight;
        const collapsedHeight = 180;

        // Only show button if content exceeds limit
        if (contentHeight <= collapsedHeight) {
            btn.style.display = 'none';
            wrapper.classList.remove('collapsed');
        }

        // Read More/Less toggle handler
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            
            const isCollapsed = wrapper.classList.contains('collapsed');
            
            if (isCollapsed) {
                // Expand
                wrapper.classList.remove('collapsed');
                btn.setAttribute('aria-expanded', 'true');
                btn.textContent = 'Read Less';
            } else {
                // Collapse
                wrapper.classList.add('collapsed');
                btn.setAttribute('aria-expanded', 'false');
                btn.textContent = 'Read More';
            }
        });
    });
    </script>
{%- endif -%}

