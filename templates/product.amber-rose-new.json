          "settings": {
            "custom_liquid": "<style>\n.ingredients-section {\n  text-align: center;\n  margin-top: 20px;\n  position: relative;\n  max-width: 100%;\n}\n\n.ingredients-title {\n  font-size: 15px;\n  font-weight: 600;\n  margin-bottom: 12px;\n}\n\n.ingredients-scroll-wrapper {\n  position: relative;\n  overflow: hidden;\n}\n\n.ingredients-scroll-container {\n  display: flex;\n  overflow-x: auto;\n  scroll-behavior: smooth;\n  padding: 5px 10px;\n  gap: 10px;\n  -webkit-overflow-scrolling: touch;\n}\n\n.ingredients-scroll-container::-webkit-scrollbar {\n  display: none;\n}\n\n.ingredients-item {\n  flex: 0 0 auto;\n  width: 110px;\n  text-align: center;\n}\n\n.ingredients-item img {\n  width: 75px;\n  height: 75px;\n  border-radius: 10px;\n  object-fit: cover;\n}\n\n.ingredients-item p {\n  margin-top: 6px;\n  font-weight: 600;\n  font-size: 13px;\n}\n\n.scroll-arrow {\n  position: absolute;\n  top: 50%;\n  transform: translateY(-50%);\n  font-size: 24px;\n  color: #444;\n  background-color: rgba(255,255,255,0.85);\n  border-radius: 50%;\n  width: 30px;\n  height: 30px;\n  line-height: 30px;\n  text-align: center;\n  cursor: pointer;\n  z-index: 1;\n  user-select: none;\n  box-shadow: 0 0 4px rgba(0,0,0,0.15);\n}\n\n.scroll-arrow.left {\n  left: 5px;\n}\n\n.scroll-arrow.right {\n  right: 5px;\n}\n\n@media (max-width: 600px) {\n  .scroll-arrow {\n    display: none;\n  }\n}\n</style>\n\n<section class=\"ingredients-section\">\n\n  <div class=\"ingredients-title\">Ingredients Behind the Fragrance</div>\n\n  <div class=\"ingredients-scroll-wrapper\">\n    <div class=\"scroll-arrow left\" onclick=\"scrollLeft()\">‹</div>\n    <div class=\"scroll-arrow right\" onclick=\"scrollRight()\">›</div>\n\n    <div class=\"ingredients-scroll-container\" id=\"scroll-container\">\n\n      <div class=\"ingredients-item\">\n        <img loading=\"lazy\" src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/slice-bergamot-white-background-65499701.webp?v=1750157355\" alt=\"Bergamot\">\n        <p>Bergamot</p>\n      </div>\n\n      <div class=\"ingredients-item\">\n        <img loading=\"lazy\" src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/360_F_771520262_W99x0hfRd7poAfGaasglg5GEOUSAul6h.jpg?v=1750157355\" alt=\"Galbanum\">\n        <p>Galbanum</p>\n      </div>\n\n      <div class=\"ingredients-item\">\n        <img loading=\"lazy\" src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/pink-pepper-isolated-white-background_269410-1578.avif?v=1750157354\" alt=\"Pink Pepper\">\n        <p>Pink Pepper</p>\n      </div>\n\n      <div class=\"ingredients-item\">\n        <img loading=\"lazy\" src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/damask-rose-flower-isolated-on-600nw-2310595795.webp?v=1750157355\" alt=\"Damask Rose\">\n        <p>Damask Rose</p>\n      </div>\n\n      <div class=\"ingredients-item\">\n        <img loading=\"lazy\" src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/istockphoto-1173075018-612x612.jpg?v=1750157355\" alt=\"Angelica\">\n        <p>Angelica</p>\n      </div>\n\n      <div class=\"ingredients-item\">\n        <img loading=\"lazy\" src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/natural-amber-piece-yellow-opaque-600nw-2084058940.webp?v=1750149491\" alt=\"Amber\">\n        <p>Amber</p>\n      </div>\n\n      <div class=\"ingredients-item\">\n        <img loading=\"lazy\" src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/musc_40889348-c0ac-4c43-a531-6062b1afb5ca.webp?v=1750157355\" alt=\"White Musk\">\n        <p>White Musk</p>\n      </div>\n\n      <div class=\"ingredients-item\">\n        <img loading=\"lazy\" src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/cashmeran_d55f10c1-6dc6-4c25-8724-fdb1d1618319.jpg?v=1750157355\" alt=\"Cashmeran\">\n        <p>Cashmeran</p>\n      </div>\n\n      <div class=\"ingredients-item\">\n        <img loading=\"lazy\" src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/red-rose-on-white-background-free-photo.jpg?v=1750157355\" alt=\"Rose Bloom\">\n        <p>Rose Bloom</p>\n      </div>\n\n    </div>\n  </div>\n\n</section>\n\n<script>\nfunction scrollLeft() {\n  document.getElementById(\"scroll-container\").scrollBy({ left: -180, behavior: 'smooth' });\n}\n\nfunction scrollRight() {\n  document.getElementById(\"scroll-container\").scrollBy({ left: 180, behavior: 'smooth' });\n}\n</script>"
