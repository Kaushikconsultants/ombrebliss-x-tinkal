        "custom_liquid_wRf4mk": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<style>\n.lush-ingredients-section {\n  text-align: center;\n  margin-top: 20px;\n  position: relative;\n  max-width: 100%;\n}\n\n.lush-ingredients-title {\n  font-size: 15px;\n  font-weight: 600;\n  margin-bottom: 12px;\n}\n\n.lush-ingredients-scroll-wrapper {\n  position: relative;\n  overflow: hidden;\n}\n\n.lush-ingredients-scroll-container {\n  display: flex;\n  overflow-x: auto;\n  scroll-behavior: smooth;\n  padding: 5px 10px 12px;\n  gap: 10px;\n  -webkit-overflow-scrolling: touch;\n}\n\n/* Scrollbar visible */\n.lush-ingredients-scroll-container::-webkit-scrollbar {\n  height: 6px;\n}\n\n.lush-ingredients-scroll-container::-webkit-scrollbar-track {\n  background: #f1f1f1;\n  border-radius: 10px;\n}\n\n.lush-ingredients-scroll-container::-webkit-scrollbar-thumb {\n  background: #777;\n  border-radius: 10px;\n}\n\n.lush-ingredients-scroll-container {\n  scrollbar-width: thin;\n  scrollbar-color: #777 #f1f1f1;\n}\n\n.lush-ingredients-item {\n  flex: 0 0 auto;\n  width: 110px;\n  text-align: center;\n}\n\n.lush-ingredients-item img {\n  width: 75px;\n  height: 75px;\n  border-radius: 10px;\n  object-fit: cover;\n  aspect-ratio: 1 / 1;\n  display: block;\n  margin: 0 auto;\n}\n\n.lush-ingredients-item p {\n  margin-top: 6px;\n  font-weight: 600;\n  font-size: 13px;\n  line-height: 1.2;\n  color: #000;\n}\n\n.lush-scroll-arrow {\n  position: absolute;\n  top: 45%;\n  transform: translateY(-50%);\n  font-size: 24px;\n  color: #444;\n  background-color: rgba(255,255,255,0.85);\n  border-radius: 50%;\n  width: 30px;\n  height: 30px;\n  line-height: 30px;\n  text-align: center;\n  cursor: pointer;\n  z-index: 2;\n  user-select: none;\n  box-shadow: 0 0 4px rgba(0,0,0,0.15);\n}\n\n.lush-scroll-arrow.left {\n  left: 5px;\n}\n\n.lush-scroll-arrow.right {\n  right: 5px;\n}\n\n@media (max-width: 600px) {\n  .lush-scroll-arrow {\n    display: none;\n  }\n\n  .lush-ingredients-scroll-container {\n    padding-bottom: 10px;\n  }\n}\n</style>\n\n<section class=\"lush-ingredients-section\">\n\n  <div class=\"lush-ingredients-title\">Ingredients Behind the Fragrance</div>\n\n  <div class=\"lush-ingredients-scroll-wrapper\">\n    <div class=\"lush-scroll-arrow left\" onclick=\"scrollLushIngredientsLeft()\">‹</div>\n    <div class=\"lush-scroll-arrow right\" onclick=\"scrollLushIngredientsRight()\">›</div>\n\n    <div class=\"lush-ingredients-scroll-container\" id=\"lush-ingredients-scroll-container\">\n\n      <div class=\"lush-ingredients-item\">\n        <img loading=\"lazy\" src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/candied-pear.webp?v=1782296706&width=150\" width=\"75\" height=\"75\" alt=\"Candied Pear\">\n        <p>Candied Pear</p>\n      </div>\n\n      <div class=\"lush-ingredients-item\">\n        <img loading=\"lazy\" src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/violet-leaves.webp?v=1782296706&width=150\" width=\"75\" height=\"75\" alt=\"Violet Leaves\">\n        <p>Violet Leaves</p>\n      </div>\n\n      <div class=\"lush-ingredients-item\">\n        <img loading=\"lazy\" src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/ylang-ylang.webp?v=1782296706&width=150\" width=\"75\" height=\"75\" alt=\"Ylang Ylang\">\n        <p>Ylang Ylang</p>\n      </div>\n\n      <div class=\"lush-ingredients-item\">\n        <img loading=\"lazy\" src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/jasmine_84a757be-c1f4-4c3f-96cc-e29746ba985b.webp?v=1782296706&width=150\" width=\"75\" height=\"75\" alt=\"Jasmine\">\n        <p>Jasmine</p>\n      </div>\n\n      <div class=\"lush-ingredients-item\">\n        <img loading=\"lazy\" src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/bubble-gum.webp?v=1782296707&width=150\" width=\"75\" height=\"75\" alt=\"Bubble Gum\">\n        <p>Bubble Gum</p>\n      </div>\n\n      <div class=\"lush-ingredients-item\">\n        <img loading=\"lazy\" src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/white-caramel.webp?v=1782296707&width=150\" width=\"75\" height=\"75\" alt=\"White Caramel\">\n        <p>White Caramel</p>\n      </div>\n\n      <div class=\"lush-ingredients-item\">\n        <img loading=\"lazy\" src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/sandalwood.webp?v=1782296707&width=150\" width=\"75\" height=\"75\" alt=\"Sandalwood\">\n        <p>Sandalwood</p>\n      </div>\n\n      <div class=\"lush-ingredients-item\">\n        <img loading=\"lazy\" src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/patchouli_edd4d9e9-2a69-4d87-b32b-0a0fb9573df1.webp?v=1782296706&width=150\" width=\"75\" height=\"75\" alt=\"Patchouli\">\n        <p>Patchouli</p>\n      </div>\n\n      <div class=\"lush-ingredients-item\">\n        <img loading=\"lazy\" src=\"https://cdn.shopify.com/s/files/1/0694/0478/6914/files/rock-sugar.webp?v=1782296706&width=150\" width=\"75\" height=\"75\" alt=\"Rock Sugar\">\n        <p>Rock Sugar</p>\n      </div>\n\n    </div>\n  </div>\n\n</section>\n\n<script>\nfunction scrollLushIngredientsLeft() {\n  document.getElementById(\"lush-ingredients-scroll-container\").scrollBy({\n    left: -180,\n    behavior: \"smooth\"\n  });\n}\n\nfunction scrollLushIngredientsRight() {\n  document.getElementById(\"lush-ingredients-scroll-container\").scrollBy({\n    left: 180,\n    behavior: \"smooth\"\n  });\n}\n</script>"
